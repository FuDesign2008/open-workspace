{
  "name": "open-workspace",
  "version": "0.2.0",
  "description": "Multi-root workspace support for OpenCode and Claude Code via MCP, enabling VS Code .code-workspace file parsing and cross-directory operations.",
  "repository": {
    "type": "git",
    "url": "https://github.com/FuDesign2008/open-workspace.git"
  },
  "bugs": {
    "url": "https://github.com/FuDesign2008/open-workspace/issues"
  },
  "homepage": "https://github.com/FuDesign2008/open-workspace#readme",
  "type": "module",
  "license": "MIT",
  "bin": {
    "open-workspace": "./dist/server.js"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "skills",
    "src/index.ts",
    "src/parser.ts",
    "src/state.ts",
    "src/server.ts",
    "src/workspace-tool-core.ts",
    "src/tools/list.ts",
    "src/tools/select.ts",
    "src/tools/parse.ts",
    "src/tools/read.ts",
    "src/tools/grep.ts",
    "src/tools/glob.ts"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@opencode-ai/plugin": "^1.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.4"
  }
}
